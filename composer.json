{
    "name": "jurajcekan/simple-php-webhook",
    "description": "Simple PHP Webhook handler for automated Git pull and Laravel cache clearing",
    "license": "MIT",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SimplePhpWebhook\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SimplePhpWebhook\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
